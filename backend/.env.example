# PostgreSQL connection string
# 로컬 개발: docker-compose up -d db 후 사용
# GCP VM: postgresql://balanceuser:PASSWORD@localhost:5432/balance_game
# GCP VM: 같은 DB(gdpworldcup), balance 스키마 분리
# DATABASE_URL="postgresql://gdpuser:PASSWORD@localhost:5432/gdpworldcup?schema=balance"
# 로컬 개발용:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gdpworldcup?schema=balance"

# Admin API key (사용 시 X-Admin-Key 헤더에 이 값을 넣으세요)
ADMIN_SECRET_KEY="change-me-in-production"

# 앱인토스 OAuth mTLS 인증서 경로 (콘솔에서 발급)
AIT_MTLS_CERT_PATH="./certs/ait-cert.pem"
AIT_MTLS_KEY_PATH="./certs/ait-key.pem"

# 탈퇴(unlink) 콜백 시크릿 — 앱인토스 콘솔 > 연결 끊기 설정에서 등록
# Basic Auth: we-balance-game:<AIT_UNLINK_SECRET>
AIT_UNLINK_SECRET="change-me-in-production"

# CORS 허용 도메인 (운영 시 토스 WebView 도메인으로 제한)
ALLOWED_ORIGIN="*"

# Port
# 로컬: 8080
# GCP VM: 4001 (GDP 퀴즈 앱이 4000을 사용하므로 4001 사용)
PORT=8080
